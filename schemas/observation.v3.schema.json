{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://becivic.be/schemas/observation.v3.schema.json",
  "title": "Be Civic — Observation submission (v3)",
  "description": "Single event observation submitted by a consuming agent. v3 mirrors the bc-docs canonical observation schema and reflects the round-7.3 spec state: the eight legacy event_types from CLAUDE.md §8 are retained for harness-side authoring, `accuracy_concern` extends to paths via `target_type: 'path'`, and Worker-set fields enforce best-effort scrub provenance. v3 is the harness-side authoritative shape; the Worker accepts the proper subset corresponding to its current event-type allow-list (see `schemas.md §6.2.1`).",
  "type": "object",

  "required": [
    "schema_version",
    "observation_id",
    "session_id",
    "submitted_at",
    "submitting_agent",
    "submission_contract_version",
    "declared_capabilities",
    "skill_id",
    "skill_version",
    "context",
    "event_type",
    "content"
  ],

  "additionalProperties": false,

  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 3,
      "description": "Schema version. v3 = round-7.3 harness-side shape."
    },

    "observation_id": {
      "type": "string",
      "pattern": "^obs_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "`obs_` prefix followed by lowercase UUIDv7. Generated by the submitting agent.",
      "examples": ["obs_018f8a3a-1234-7abc-89ef-0123456789ab"]
    },

    "session_id": {
      "type": "string",
      "pattern": "^ses_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "`ses_` prefix followed by lowercase UUIDv7. Same across all events from a single session."
    },

    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp with timezone offset. The Worker normalises to UTC."
    },

    "submitting_agent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z][A-Za-z0-9._+@()\\- ]*/[A-Za-z0-9._+@()\\- ]+$",
      "description": "Free-form `<runtime-id>/<version>` runtime identifier. Informational only — never used for trust decisions.",
      "examples": ["claude-personal/1.2", "le-chat-mistral/1.0", "gpt-5/2026-04"]
    },

    "submission_contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$",
      "description": "Semver of the submission contract the agent followed."
    },

    "declared_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "file_read",
          "structured_output",
          "multi_turn",
          "tool_execution",
          "pdf_generation",
          "web_fetch",
          "vision",
          "local_filesystem"
        ]
      },
      "uniqueItems": true,
      "description": "Capability tokens the agent self-declares. Worker enforces tier per spec §6.7."
    },

    "skill_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "maxLength": 100,
      "description": "Kebab-case skill ID. Flat namespace, no slashes."
    },

    "skill_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$",
      "description": "Semver of the skill at the time the agent loaded it."
    },

    "target_type": {
      "type": "string",
      "enum": ["skill", "path"],
      "default": "skill",
      "description": "Resolution domain for this observation. `skill` (default) targets a skill canonical; `path` (round-7.3) targets a Path Directory entry. When `path`, `skill_id` carries the path id."
    },

    "context": {
      "type": "object",
      "required": ["language_used", "country"],
      "additionalProperties": false,
      "properties": {
        "language_used": {
          "type": "string",
          "enum": ["fr", "nl", "de", "en"]
        },
        "country": {
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "default": "be"
        },
        "region": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "commune": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9]{5}-[a-z][a-z0-9-]*[a-z0-9]$" },
            { "type": "null" }
          ]
        },
        "applies_to_match": {
          "type": "object",
          "maxProperties": 10,
          "additionalProperties": {
            "type": ["string", "array"],
            "maxLength": 200,
            "items": { "type": "string", "maxLength": 200 },
            "maxItems": 10
          }
        }
      }
    },

    "event_type": {
      "type": "string",
      "enum": [
        "document_skill_omitted",
        "document_skill_overstated",
        "step_skill_omitted",
        "step_skill_overstated",
        "volatile_value",
        "accuracy_concern",
        "session_outcome",
        "session_pause"
      ],
      "description": "Closed enum mirroring CLAUDE.md §8. The Worker further filters to its current allow-list; `session_outcome` and `session_pause` are local-only per round-7.3 (the harness MUST NOT submit them — kept in the enum so they validate at write to the local buffer)."
    },

    "content": {
      "description": "Shape varies by event_type. See allOf branches below."
    },

    "retrospective": {
      "type": "boolean",
      "default": false,
      "description": "True if the observation reports an experience that completed before the user discovered the system."
    },

    "notes": {
      "type": "string",
      "maxLength": 200,
      "description": "Freeform commentary, scrubbed. ≤200 chars. Reference the category, not the user's own case."
    },

    "validation": {
      "type": "object",
      "required": ["validated_at", "regex_passes"],
      "additionalProperties": false,
      "properties": {
        "validated_at": { "type": "string", "format": "date-time" },
        "regex_passes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        }
      },
      "description": "Worker-set on commit. Submissions arriving with this populated are rejected."
    },

    "compaction_status": {
      "type": "string",
      "enum": [
        "unprocessed",
        "considered_no_action",
        "promoted",
        "superseded",
        "declined"
      ],
      "default": "unprocessed",
      "description": "Set by automation."
    },

    "compaction_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["run_id", "prompt_version", "outcome", "decision_at"],
        "additionalProperties": false,
        "properties": {
          "run_id": {
            "type": "string",
            "pattern": "^run_[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
          },
          "prompt_version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
          },
          "outcome": {
            "type": "string",
            "enum": ["considered_no_action", "promoted", "superseded", "declined"]
          },
          "decision_at": { "type": "string", "format": "date-time" },
          "decline_reason": { "type": "string", "maxLength": 500 }
        },
        "allOf": [
          {
            "if": { "properties": { "outcome": { "const": "declined" } } },
            "then": { "required": ["decline_reason"] }
          }
        ]
      }
    },

    "submitter_name": false,
    "submitter_email": false,
    "session_correlation_id": false,
    "device_id": false,
    "user_id": false,
    "user_email": false,
    "user_name": false,
    "ip_address": false,
    "github_login": false
  },

  "allOf": [
    {
      "if": { "properties": { "event_type": { "const": "document_skill_omitted" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["name", "required_by"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 200 },
              "required_by": { "type": "string", "minLength": 1, "maxLength": 200 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "document_skill_overstated" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 200 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "enum": ["step_skill_omitted", "step_skill_overstated"] } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["description"],
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string", "minLength": 1, "maxLength": 500 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "volatile_value" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["key", "observed"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "observed": { "type": ["number", "string", "integer"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "accuracy_concern" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["kind", "target"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "citation_misreference",
                  "citation_404",
                  "statutory_change",
                  "factual_error",
                  "missing_origin_coverage"
                ]
              },
              "target": { "type": "string", "minLength": 1, "maxLength": 200 },
              "evidence_url": { "type": "string", "format": "uri" },
              "scope": {
                "type": "string",
                "enum": ["general", "commune-specific", "regional-specific", "role-specific"],
                "description": "Round-7.3 path-targeted extension. Required only when target_type=path; informational otherwise."
              },
              "specifier": {
                "type": "string",
                "maxLength": 200,
                "description": "Round-7.3 path-targeted extension. NIS5 commune code, region code, or role descriptor. Required when scope != general."
              },
              "report": {
                "type": "string",
                "maxLength": 2000,
                "description": "Round-7.3 path-targeted extension. Scrubbed free text describing the customer's experience."
              },
              "evidence_date": {
                "type": "string",
                "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$"
              },
              "evidence_source": {
                "type": "string",
                "enum": ["customer-report", "citation", "corroboration"]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "session_outcome" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["outcome", "duration_bucket"],
            "additionalProperties": false,
            "properties": {
              "outcome": {
                "type": "string",
                "enum": ["success", "partial", "blocked", "abandoned", "unknown"]
              },
              "duration_bucket": {
                "type": "string",
                "enum": ["<1w", "1-4w", "1-3m", "3-6m", "6m+"]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event_type": { "const": "session_pause" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["reason", "expected_resume_window"],
            "additionalProperties": false,
            "properties": {
              "reason": {
                "type": "string",
                "enum": ["awaiting_external_document", "awaiting_appointment", "user_pause", "other"]
              },
              "expected_resume_window": {
                "type": "string",
                "enum": ["days", "weeks", "months", "unknown"]
              }
            }
          }
        }
      }
    }
  ]
}
